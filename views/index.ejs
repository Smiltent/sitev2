
<div class="lander">
    <div class="m-left">
        <div class="box m-l-stats gray-bg">
            <div class="box-header">
                <h1><i class="fa-solid fa-chart-line fa-sm"></i> stats</h1>
            </div>
            <div class="m-l-stats-container">
                <p><b>ips banned:</b> <%= counts.bots %> (<a href="/blog/bots">?</a>)</p>
                <p><b>posts:</b> <%= counts.posts %></p>

            </div>
        </div>

        <div class="box m-l-discord gray-bg">
            <div class="box-header">
                <h1><i class="fa-brands fa-discord fa-sm"></i> discord</h1>
            </div>
            <div class="m-l-discord-container">
                <div class="m-l-d-avatar">
                    <img class="m-l-d-img" src="/public/img/pfp.png" alt="Discord Profile Picture">
                    <span class="m-l-d-status" id="discordStatusDot" data-status="<%= state?.discord?.status ?? "offline" %>"></span>
                </div>
                <p class="m-l-d-desc"><span id="discordUsername">smiltene</span><span id="discordStatus"><%= state?.discord?.custom ?? "..." %></span></p>
            </div>
        </div>

        <div class="box m-l-spotify gray-bg">
            <div class="box-header">
                <h1><i class="fa-brands fa-spotify fa-sm"></i> spotify</h1>
            </div>
            <div class="m-l-spotify-container" data-hasurl="0">
                <img class="m-l-s-img" id="spotifyImg" src="<%= state?.spotify?.art ?? "/public/img/disc.png" %>" alt="Spotify Image Picture">
                <p class="m-l-s-desc"><span id="spotifySong"><%= state?.spotify?.song ?? "Listening to" %></span><span id="spotifyArtist"><%= state?.spotify?.artist ?? "nothing" %></span></p>
            </div>
        </div>

        <div class="box m-l-coding gray-bg">
            <div class="box-header">
                <h1><i class="fa-solid fa-code-branch fa-sm"></i> time spent coding</h1>
            </div>
            <div class="m-l-coding-container">
                <p><b>all time:</b> <span id="codingAllTime"><%= state?.coding?.allTime ?? "0 hrs" %></span></p>
                <p><b>today:</b> <span id="codingToday"><%= state?.coding?.today ?? "0m / 0m goal" %></span></p>
            </div>
        </div>

        <!-- <div class="box m-l-status gray-bg">
            <div class="box-header">
                <h1><i class="fa-solid fa-bars-progress fa-sm"></i></i> status</h1>
            </div>
            <div class="m-l-status-container">
                <p><span id="" style="color: var(--dgreen)">⬤</span> peanut</p>
                <p><span id="" style="color: var(--dred)">⬤</span> jelly</p>
                <p><span id="">⬤</span> jam</p>
                <p><span id="">⬤</span> forge</p>
            </div>
        </div> -->
    </div>

    <div class="m-right">
        <div class="m-r-nav">
            <a href="/whoami" class="box clickable">whoami/</a>
            <a href="/blog" class="box clickable">blog/</a>
            <a href="/projects" class="box clickable">projects/</a>
            <a href="/guestbook" class="box clickable">guestbook/</a>
            <a href="/tools" class="box clickable">tools/</a>
        </div>
    </div>
</div>
